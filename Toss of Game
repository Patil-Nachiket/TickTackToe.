import java.util.Random;

public class TicTacToe {

    // Game state variables
    static String player1 = "Player 1";
    static String player2 = "Player 2";
    static String currentPlayer;
    static char player1Symbol;
    static char player2Symbol;

    // Perform toss and assign symbols
    static void performToss() {
        Random random = new Random();
        int tossResult = random.nextInt(2); // Generates 0 or 1

        if (tossResult == 0) {
            // Player 1 starts
            currentPlayer = player1;
            player1Symbol = 'X';
            player2Symbol = 'O';
        } else {
            // Player 2 starts
            currentPlayer = player2;
            player2Symbol = 'X';
            player1Symbol = 'O';
        }
    }

    // Display toss result
    static void displayTossResult() {
        System.out.println("=== TOSS RESULT ===");
        System.out.println(player1 + " --> " + player1Symbol);
        System.out.println(player2 + " --> " + player2Symbol);
        System.out.println();
        System.out.println("*** " + currentPlayer + " goes FIRST! ***");
        System.out.println("===================");
    }

    public static void main(String[] args) {
        performToss();
        displayTossResult();
    }
}
