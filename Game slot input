import java.util.Scanner;

public class TicTacToe {

    static Scanner scanner = new Scanner(System.in);

    // Method to get slot input from the player
    static int getPlayerInput(String playerName) {
        System.out.print(playerName + ", enter your slot (1-9): ");
        int slot = scanner.nextInt();
        return slot;
    }

    public static void main(String[] args) {
        int slot = getPlayerInput("Player 1");
        System.out.println("You entered slot: " + slot);
    }
}
